{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=SANGIT;Database=InternHub;trusted_connection=True; TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "InternHub@SuperSecretKey#2025!ChangeMeInProduction$Min32Chars",
    "Issuer": "InternHub",
    "Audience": "InternHubUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Thresholds": {
    "EligibilityMinPercent": 60,
    "WeakChapterMaxPercent": 50,
    "AptitudeBonusWeight": 0.3,
    "OptionalSkillWeight": 0.15,
    "GitHubBonus": 4,
    "PortfolioBonus": 4,
    "LinkedInBonus": 2,
    "EducationOptionalBonus": 5
  },
  "TestSettings": {
    "TestDurationMinutes": 30,
    "QuestionsPerTest": 20
  },
  "ResumeParsingSettings": {
    "MinTokenLength": 2,
    "MaxSuggestionsCount": 30,
    "StopWords": [
      "the",
      "and",
      "with",
      "for",
      "use",
      "used",
      "using",
      "have",
      "has",
      "can",
      "will",
      "learn",
      "work",
      "worked",
      "experience",
      "knowledge",
      "good",
      "strong",
      "excellent",
      "proficient",
      "familiar",
      "ability",
      "skills",
      "skill",
      "year",
      "years",
      "month",
      "months",
      "project",
      "projects",
      "team",
      "teams",
      "company",
      "companies",
      "developed",
      "development",
      "built",
      "build",
      "implement",
      "implemented",
      "design",
      "designed",
      "manage",
      "managed"
    ]
  },
  "FileStorage": {
    "BasePath": "wwwroot"
  },
  "AdminSeed": {
    "Email": "admin@internhub.com",
    "Password": "Admin@1234",
    "FullName": "System Administrator"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "QuotaExceededMessage": "Too many requests. Please slow down.",
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/resume/upload",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/tests/*/submit",
        "Period": "1h",
        "Limit": 3
      },
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/register/*",
        "Period": "1h",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 20
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      } 
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SmtpUser": "your-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "FromEmail": "noreply@internhub.com",
    "FromName": "InternHub",
    "AppBaseUrl": "http://localhost:3000",
    "UseConsoleInDevelopment": false
  }
}
